  "typography": {
    "sans": "Geist, Inter, system-ui, sans-serif",
    "mono": "'Geist Mono', ui-monospace, monospace",
    "tracking": {
      "caption": "0.01em",
      "eyebrow": "0.06em",
      "ui": "-0.006em",
      "body": "-0.011em",
      "heading": "-0.017em",
      "display": "-0.022em"
    },
    "lineHeight": {
      "display": 1.1,
      "heading": 1.18,
      "body": 1.65
    },
    "numerics": "tabular-nums"
  },
  "icons": {
    "library": "lucide-react",
    "stroke": 2,
    "sizing": "1em — icon size follows font size; standalone 16/20/24px",
    "color": "currentColor"
  },
  "spacing": {
    "grid": 8,
    "fineStep": 4,
    "macroMin": 32,
    "touchTargetMin": 44
  },
  "radius": [
    8,
    12,
    16,
    20,
    24
  ],
  "shadows": {
    "sm": "0 2px 8px rgba(0,0,0,0.05)",
    "md": "0 8px 30px rgba(0,0,0,0.08)",
    "lg": "0 20px 60px rgba(0,0,0,0.12)"
  },
  "motion": {
    "durationFastMs": 200,
    "durationBaseMs": 250,
    "easeOut": "cubic-bezier(0.23, 1, 0.32, 1)",
    "easeInOut": "cubic-bezier(0.77, 0, 0.175, 1)",
    "bounce": false
  }
}
