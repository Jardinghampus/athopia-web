# ─────────────────────────────────────────────────────────────────────────────
# Athopia — .env.local.example
# Kopiera till .env.local och fyll i dina riktiga nycklar.
# ALDRIG checka in .env.local i git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Basurl utan trailing slash (används i Stripe Checkout + webhooks)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Hämtas från: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — ALDRIG i klienten! Används bara server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Clerk Auth ───────────────────────────────────────────────────────────────
# Hämtas från: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect-URLs (valfri override)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Clerk webhook (user.created → user_feed_config). Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── Admin ────────────────────────────────────────────────────────────────────
# Komma-separerad lista av Clerk user-ID:n som får nå /admin/* och /api/admin/*.
# Hitta ditt ID: Clerk Dashboard → Users → (din användare) → User ID (user_...).
# Lämnas tom → ingen är admin (admin-ytor låsta).
ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ───────────────────────────────────────────────────────────────────
# Hämtas från: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Webhook-hemlighet — hämtas via: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Sentry ───────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN aktiverar klientrapportering och kan användas lokalt
# för /sentry-example-page. SENTRY_DSN används server/edge-side.
NEXT_PUBLIC_SENTRY_DSN=https://public@example.ingest.sentry.io/project-id
SENTRY_DSN=https://public@example.ingest.sentry.io/project-id

# För uppladdning av source maps i CI/production build.
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Sportmonks-synkronisering hanteras av athopia-os (separat repo).
# athopia-web läser enbart från Supabase — ingen Sportmonks API-nycklar behövs här.

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generera: cd athopia-os/packages/notifications && pnpm exec web-push generate-vapid-keys
# Samma public key i web + os. Private key ALDRIG i klienten.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@athopia.se
